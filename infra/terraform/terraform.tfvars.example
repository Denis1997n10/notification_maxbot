# Do not deploy with this file. scripts/bootstrap_yc.sh generates a complete var-file.
environment = "dev"
cloud_id = ""
folder_id = ""
project_name = "resident-notifications"
resource_prefix = "rn"
ydb_name = "resident-notifications"
bucket_public_name = "rn-public-dev"
bucket_admin_name = "rn-admin-dev"
release_artifacts_bucket_name = "rn-release-dev"
gateway_name = "resident-notifications-api"
public_origin = "http://localhost:5173"
admin_origin = "http://localhost:5174"
public_site_url = "http://localhost:5173"
admin_site_url = "http://localhost:5174"
regioncity_api_token_secret_id = "dev-mock-regioncity-token"
regioncity_api_token_secret_version_id = ""
max_bot_token_secret_id = "dev-mock-max-bot-token"
max_bot_token_secret_version_id = ""
admin_jwt_secret_id = "dev-mock-admin-jwt-secret"
admin_jwt_secret_version_id = ""
max_webhook_secret_id = ""
max_webhook_secret_version_id = ""
function_use_mocks = true
enable_polling_timer = false
